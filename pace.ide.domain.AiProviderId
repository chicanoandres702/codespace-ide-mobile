        Language.JAVA -> spec(
            keywords = setOf(
                "public", "private", "protected", "class", "interface", "extends",
                "implements", "static", "final", "void", "return", "if", "else", "for",
                "while", "do", "switch", "case", "break", "continue", "new", "import",
